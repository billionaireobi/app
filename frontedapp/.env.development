# Development environment variables.
#
# EXPO_PUBLIC_API_URL is now AUTO-DETECTED from the Expo Metro bundler address —
# you no longer need to update this file when your IP changes.
#
# This value is only used as a fallback if auto-detection fails
# (e.g. running in a simulator without a Metro host available).
EXPO_PUBLIC_API_URL=http://localhost:8000/api/
