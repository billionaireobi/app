# Copy this file to .env.local ONLY if auto-detection is not working for you.
# (Auto-detection reads the IP from the Expo Metro bundler — works on any network.)
#
# Cases where you might need this:
#   - Django running on a non-standard port (not 8000)
#   - Django on a different machine than the Expo dev server
#   - Running in an iOS/Android simulator where Metro host is unavailable
#
# .env.local is gitignored — safe to put your personal config here.
#
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8000/api/
